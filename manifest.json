{
  "manifest_version": 3,
  "name": "Amazon Seller Scraper",
  "version": "1.2.9",
  "description": "ASIN'den satıcıları ve satıcı mağaza ürünlerini toplar",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "tabs",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://51.102.128.78:3009/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/dp/*", "https://www.amazon.com/gp/offer-listing/*"],
      "js": ["utils/helpers.js", "content/product.js", "content/offers.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.amazon.com/s*"],
      "js": ["utils/helpers.js", "content/store.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
